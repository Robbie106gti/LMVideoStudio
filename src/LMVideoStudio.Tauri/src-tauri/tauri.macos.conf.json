{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.lmvideostudio.desktop",
  "bundle": {
    "targets": ["dmg"],
    "icon": ["icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null,
      "hardenedRuntime": true
    },
    "externalBin": [
      "sidecars/LMVideoStudio.Host",
      "sidecars/lmvs_worker/run_worker"
    ],
    "resources": [
      "../../../docs/project.schema.json",
      "../../../config/**/*",
      "../../../scripts/**/*.ps1",
      "../../../scripts/**/*.sh",
      "../../../sidecars/lmvs_worker/lmvs_worker/**/*",
      "../../../sidecars/lmvs_worker/lib/**/*",
      "../../../sidecars/lmvs_worker/.venv/**/*",
      "../../../sidecars/lmvs_worker/bin/**/*",
      "../../../sidecars/lmvs_worker/run_worker.sh",
      "../../../sidecars/lmvs_worker/run_worker.cmd",
      "../../../sidecars/lmvs_worker/requirements-worker.txt"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Robbie106gti/LMVideoStudio/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY"
    }
  }
}
